[Unit]
Description=SDR Temperature Telegram Bot
After=sdr-temps.service

[Service]
Type=simple
User=jsn
Environment=HOME=/home/jsn
WorkingDirectory=/home/jsn/cc_projects/sdr

ExecStart=/home/jsn/.pyenv/versions/3.14.3/bin/python3 tg_temps.py

Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target

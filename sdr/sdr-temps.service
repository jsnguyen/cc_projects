[Unit]
Description=SDR Temperature Logger
After=network.target

[Service]
Type=simple
User=jsn
Environment=HOME=/home/jsn
WorkingDirectory=/home/jsn/cc_projects/sdr

ExecStart=/bin/bash -c 'rtl_433 -F json -M time:iso 2>/dev/null | /home/jsn/.pyenv/versions/3.14.3/bin/python3 sdr_logger.py --dir sdr'

TimeoutStartSec=30
TimeoutStopSec=15

Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
